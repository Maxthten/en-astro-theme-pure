---
import config from '@/site-config'

import '@waline/client/style'

import { cn } from 'astro-pure/utils'

interface Props {
  class?: string
  sharedId?: string
}

const { class: className, sharedId = 'about-guestbook' } = Astro.props as Props
---

{
  config.integ.waline.enable && (
    <guestbook-component data-shared-id={sharedId}>
      <div id='waline-guestbook' class={cn('not-prose', className)}>
        Loading guestbook...
      </div>
    </guestbook-component>
  )
}

<script>
  import { init as walineInit } from '@waline/client'
  import type { WalineEmojiPresets } from '@waline/client'
  import config from 'virtual:config'

  const walineConfig = config.integ.waline
  const pendingInputHint = 'Leave a note if you want. (Visible after review)'
  const pendingStatusText = '(Sent successfully, only visible to you until approved)'
  const guestbookFetchHandlersKey = '__guestbookWalineFetchHandlers__'
  const guestbookFetchPatchedKey = '__guestbookWalineFetchPatched__'

  function getWalineScope(hostname: string) {
    const host = hostname.toLowerCase()

    if (host === 'localhost' || host === '127.0.0.1') return 'localhost'

    const [subdomain] = host.split('.')

    if (subdomain === 'zh' || subdomain === 'en') return subdomain

    return host
  }

  function enhanceGuestbookUI(root: HTMLElement) {
    const info = root.querySelector<HTMLElement>('.wl-info')

    if (info && !info.querySelector('.wl-pending-hint')) {
      const hint = document.createElement('span')
      hint.className = 'wl-pending-hint'
      hint.textContent = '(Visible after review)'
      info.prepend(hint)
    }

    const editor = root.querySelector<HTMLTextAreaElement>('.wl-editor')

    if (editor && editor.placeholder !== pendingInputHint) {
      editor.placeholder = pendingInputHint
    }

    root.querySelectorAll<HTMLElement>('.wl-card-item').forEach((item) => {
      const status = Array.from(item.querySelectorAll<HTMLElement>('.wl-meta > span')).find((span) =>
        span.textContent?.trim().includes('Waiting')
      )

      if (!status) return

      status.textContent = pendingStatusText
      status.classList.add('wl-pending-status')
      item.classList.add('wl-pending-comment')
    })
  }

  function ensurePendingPreviewList(root: HTMLElement) {
    let list = root.querySelector<HTMLElement>('.wl-pending-preview-list')

    if (list) return list

    list = document.createElement('div')
    list.className = 'wl-pending-preview-list'

    const comments =
      root.querySelector<HTMLElement>('.wl-cards') ||
      root.querySelector<HTMLElement>('.wl-empty')?.parentElement ||
      root

    comments.parentElement?.insertBefore(list, comments)

    return list
  }

  function renderPendingPreview(root: HTMLElement, comment: Record<string, unknown>) {
    const list = ensurePendingPreviewList(root)
    const objectId = String(comment.objectId || Date.now())
    let card = list.querySelector<HTMLElement>(`.wl-pending-preview[data-object-id="${objectId}"]`)

    if (!card) {
      card = document.createElement('article')
      card.className = 'wl-pending-preview'
      card.dataset.objectId = objectId
      card.innerHTML = `
        <div class="wl-pending-preview-head">
          <div class="wl-pending-preview-user">
            <img class="wl-pending-preview-avatar" alt="" />
            <div class="wl-pending-preview-meta">
              <div class="wl-pending-preview-nick"></div>
              <div class="wl-pending-preview-status"></div>
            </div>
          </div>
          <time class="wl-pending-preview-time"></time>
        </div>
        <div class="wl-pending-preview-content"></div>
      `
      list.prepend(card)
    }

    const avatar = card.querySelector<HTMLImageElement>('.wl-pending-preview-avatar')
    const nick = card.querySelector<HTMLElement>('.wl-pending-preview-nick')
    const status = card.querySelector<HTMLElement>('.wl-pending-preview-status')
    const time = card.querySelector<HTMLElement>('.wl-pending-preview-time')
    const content = card.querySelector<HTMLElement>('.wl-pending-preview-content')

    const avatarUrl = typeof comment.avatar === 'string' ? comment.avatar : ''
    if (avatar) {
      avatar.src = avatarUrl
      avatar.hidden = !avatarUrl
    }

    if (nick) nick.textContent = typeof comment.nick === 'string' ? comment.nick : 'Anonymous'
    if (status) status.textContent = pendingStatusText
    if (time) time.textContent = 'Just now'
    if (content) content.innerHTML = typeof comment.comment === 'string' ? comment.comment : ''

    root.querySelector<HTMLElement>('.wl-empty')?.remove()
  }

  function installGuestbookFetchInterceptor(
    path: string,
    serverURL: string,
    onWaiting: (comment: Record<string, unknown>) => void
  ) {
    const normalizedURL = `${serverURL.replace(/\/?$/, '/')}api/comment`
    const globalState = globalThis as typeof globalThis & {
      [guestbookFetchHandlersKey]?: Array<{
        path: string
        serverURL: string
        onWaiting: (comment: Record<string, unknown>) => void
      }>
      [guestbookFetchPatchedKey]?: boolean
    }

    const handlers = (globalState[guestbookFetchHandlersKey] ||= [])
    handlers.push({ path, serverURL: normalizedURL, onWaiting })

    if (globalState[guestbookFetchPatchedKey]) return

    const originalFetch = globalThis.fetch.bind(globalThis)

    globalThis.fetch = async (input, init) => {
      const request = input instanceof Request ? input : null
      const url =
        typeof input === 'string'
          ? input
          : input instanceof URL
            ? input.href
            : request?.url || ''
      const method = (init?.method || request?.method || 'GET').toUpperCase()
      const response = await originalFetch(input, init)

      if (method !== 'POST') return response

      const matchedHandlers = handlers.filter((handler) => url.startsWith(handler.serverURL))

      if (!matchedHandlers.length) return response

      try {
        const bodyText =
          typeof init?.body === 'string'
            ? init.body
            : request
              ? await request.clone().text()
              : ''
        const payload = bodyText ? JSON.parse(bodyText) : {}
        const data = await response.clone().json()

        matchedHandlers.forEach((handler) => {
          if (payload.url === handler.path && data?.data?.status === 'waiting') {
            handler.onWaiting(data.data as Record<string, unknown>)
          }
        })
      } catch {}

      return response
    }

    globalState[guestbookFetchPatchedKey] = true
  }

  class Guestbook extends HTMLElement {
    connectedCallback() {
      ;(globalThis as unknown as { __VUE_OPTIONS_API__: boolean }).__VUE_OPTIONS_API__ = true
      ;(globalThis as unknown as { __VUE_PROD_DEVTOOLS__: boolean }).__VUE_PROD_DEVTOOLS__ = false
      ;(
        globalThis as unknown as { __VUE_PROD_HYDRATION_MISMATCH_DETAILS__: boolean }
      ).__VUE_PROD_HYDRATION_MISMATCH_DETAILS__ = false

      const slug = this.dataset.sharedId || 'about-guestbook'
      const path = `${getWalineScope(window.location.hostname)}:${slug}`

      const emoji = walineConfig.emoji?.map(
        (preset) => `${config.npmCDN}/@waline/emojis@1.2.0/${preset}` as WalineEmojiPresets
      )

      walineInit({
        el: '#waline-guestbook',
        serverURL: walineConfig.server || '',
        path,
        emoji,
        ...walineConfig.additionalConfigs,
        search: false,
        pageview: false,
        comment: false,
        meta: ['nick', 'mail', 'link'],
        requiredMeta: ['nick'],
        login: 'enable',
        pageSize: 10,
        wordLimit: [0, 1000],
        imageUploader: false,
        dark: 'html.dark',
        locale: {
          nick: 'Name',
          mail: 'Email',
          link: 'Website',
          optional: 'Optional',
          placeholder: pendingInputHint,
          sofa: 'No messages yet. You can start the conversation.',
          submit: 'Leave a message',
          comment: 'Messages',
          waiting: 'Waiting'
        }
      })

      const root = this.querySelector<HTMLElement>('#waline-guestbook')

      if (!root) return

      installGuestbookFetchInterceptor(path, walineConfig.server || '', (comment) => {
        renderPendingPreview(root, comment)
        enhanceGuestbookUI(root)
      })

      enhanceGuestbookUI(root)

      const observer = new MutationObserver(() => {
        enhanceGuestbookUI(root)
      })

      observer.observe(root, { childList: true, subtree: true })
    }
  }

  if (walineConfig.enable && !customElements.get('guestbook-component')) {
    customElements.define('guestbook-component', Guestbook)
  }
</script>

<style>
  #waline-guestbook {
    --waline-font-size: 16px;
    --waline-white: hsl(var(--background) / var(--un-bg-opacity, 1));
    --waline-light-grey: #999;
    --waline-dark-grey: #666;
    --waline-theme-color: hsl(var(--foreground) / var(--un-text-opacity, 1));
    --waline-active-color: hsl(var(--primary) / var(--un-text-opacity, 1));
    --waline-color: hsl(var(--muted-foreground) / var(--un-text-opacity, 1));
    --waline-bg-color: hsl(var(--muted) / var(--un-bg-opacity, 1));
    --waline-bg-color-light: hsl(var(--input) / var(--un-text-opacity, 1));
    --waline-border-color: hsl(var(--border) / var(--un-border-opacity, 1));
    --waline-border: 1px solid var(--waline-border-color);
    --waline-avatar-radius: 50%;
    --waline-box-shadow: none;
  }

  #waline-guestbook :global(.wl-content, .wl-text, .wl-comment-text, .wl-item, .wl-card-item, a) {
    max-width: 100%;
  }

  #waline-guestbook :global(.wl-meta, .wl-content, .wl-text, .wl-comment-text) {
    word-wrap: break-word;
    word-break: break-word;
    overflow-wrap: anywhere;
  }

  #waline-guestbook :global(.wl-info) {
    gap: 0.5rem;
  }

  #waline-guestbook :global(.wl-pending-hint) {
    margin-inline-end: auto;
    color: hsl(var(--muted-foreground) / 0.9);
    font-size: 0.75em;
    white-space: nowrap;
  }

  #waline-guestbook :global(.wl-pending-status) {
    background: rgb(254 249 195);
    color: rgb(161 98 7);
  }

  #waline-guestbook :global(.wl-pending-comment > .wl-card) {
    border-bottom-color: rgb(253 224 71 / 0.55);
  }

  :global(.dark) #waline-guestbook :global(.wl-pending-status) {
    background: rgb(113 63 18 / 0.35);
    color: rgb(253 224 71);
  }

  #waline-guestbook :global(.wl-pending-preview-list) {
    margin-bottom: 1rem;
  }

  #waline-guestbook :global(.wl-pending-preview) {
    margin-bottom: 0.75rem;
    padding: 0.875rem 1rem;
    border: 1px solid rgb(250 204 21 / 0.55);
    border-radius: 0.875rem;
    background: rgb(254 252 232);
    color: hsl(var(--foreground) / var(--un-text-opacity, 1));
  }

  #waline-guestbook :global(.wl-pending-preview-head) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.625rem;
  }

  #waline-guestbook :global(.wl-pending-preview-user) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  #waline-guestbook :global(.wl-pending-preview-avatar) {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid rgb(250 204 21 / 0.4);
    background: rgb(255 255 255 / 0.7);
  }

  #waline-guestbook :global(.wl-pending-preview-meta) {
    min-width: 0;
  }

  #waline-guestbook :global(.wl-pending-preview-nick) {
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.35;
  }

  #waline-guestbook :global(.wl-pending-preview-status) {
    margin-top: 0.2rem;
    color: rgb(161 98 7);
    font-size: 0.75rem;
    line-height: 1.5;
  }

  #waline-guestbook :global(.wl-pending-preview-time) {
    flex-shrink: 0;
    color: rgb(161 98 7);
    font-size: 0.75rem;
    line-height: 1.5;
  }

  #waline-guestbook :global(.wl-pending-preview-content) {
    white-space: pre-wrap;
    word-break: break-word;
    overflow-wrap: anywhere;
    line-height: 1.8;
  }

  :global(.dark) #waline-guestbook :global(.wl-pending-preview) {
    border-color: rgb(202 138 4 / 0.45);
    background: rgb(69 26 3 / 0.35);
  }

  :global(.dark) #waline-guestbook :global(.wl-pending-preview-avatar) {
    border-color: rgb(202 138 4 / 0.4);
    background: rgb(24 24 27 / 0.65);
  }

  :global(.dark) #waline-guestbook :global(.wl-pending-preview-status),
  :global(.dark) #waline-guestbook :global(.wl-pending-preview-time) {
    color: rgb(253 224 71);
  }
</style>
